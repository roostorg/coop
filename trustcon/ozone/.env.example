# Local Ozone labeler test config. Copy to .env and fill the two FILL-ME lines
# with the Bluesky service account you create for the labeler. The rest is
# auto-filled at deploy time or fine as-is for a local test.
#
#   cp trustcon/ozone/.env.example trustcon/ozone/.env
#   # then edit the two FILL-ME lines below
#
# .env is gitignored, so the app password never lands in the repo or chat.

# ---- YOU fill these (the labeler service account) ----
SERVICE_IDENTIFIER=your-labeler-handle.bsky.social   # FILL ME (handle)
SERVICE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx              # FILL ME (app password)
SERVICE_PDS_URL=https://bsky.social

# ---- Auto-filled at deploy (leave as-is; resolved/generated for you) ----
OZONE_SERVER_DID=RESOLVED_AT_DEPLOY
OZONE_ADMIN_DIDS=RESOLVED_AT_DEPLOY
OZONE_SIGNING_KEY_HEX=GENERATED_AT_DEPLOY
OZONE_ADMIN_PASSWORD=GENERATED_AT_DEPLOY

# ---- Local test defaults (fine as-is) ----
OZONE_PUBLIC_URL=http://localhost:3001
OZONE_DB_POSTGRES_URL=postgresql://postgres:postgres@ozone-db:5432/ozone
OZONE_DB_MIGRATE=1
OZONE_APPVIEW_URL=https://api.bsky.app
OZONE_APPVIEW_DID=did:web:api.bsky.app
OZONE_DID_PLC_URL=https://plc.directory
