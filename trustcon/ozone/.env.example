# Ozone service configuration. See https://github.com/bluesky-social/ozone HOSTING.md
# Generate the signing key with:
#   openssl ecparam --name secp256k1 --genkey --noout --outform DER | tail --bytes=+8 | head --bytes=32 | xxd --plain --cols 32
OZONE_SERVER_DID=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
OZONE_PUBLIC_URL=https://ozone.your-workshop-domain.example
OZONE_ADMIN_DIDS=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
OZONE_ADMIN_PASSWORD=change-me
OZONE_SIGNING_KEY_HEX=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OZONE_DB_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/ozone
OZONE_DB_MIGRATE=1

# Used by publish-labeler-record.mjs to declare the bleep/bloop label values
SERVICE_PDS_URL=https://bsky.social
SERVICE_IDENTIFIER=labeler.your-workshop-domain.example
SERVICE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
