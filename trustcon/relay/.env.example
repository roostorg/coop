# Label relay configuration.
PORT=8090

# Ozone labeler service
OZONE_URL=https://ozone.your-workshop-domain.example
OZONE_SERVER_DID=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx

# Admin account used to emit labels (must be listed in OZONE_ADMIN_DIDS on Ozone)
ADMIN_PDS_URL=https://bsky.social
ADMIN_IDENTIFIER=labeler-admin.your-workshop-domain.example
ADMIN_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ADMIN_DID=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx

# Guardrail: the only label values this relay will ever emit
ALLOWED_LABELS=bleep,bloop

# Public AppView for CID resolution (no auth)
APPVIEW_URL=https://public.api.bsky.app
